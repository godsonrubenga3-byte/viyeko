rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "godsonrubenga3@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function incomingDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }

    // Test Connection Rule
    match /test/connection {
      allow read: if true;
    }

    // User Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['admin', 'user'];
    }

    // Vehicle Rules
    match /vehicles/{vehicleId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if incomingDocOwner() && isValidVehicle(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && incomingDocOwner() && isValidVehicle(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    function isValidVehicle(data) {
      return data.keys().hasAll(['id', 'uid', 'make', 'model', 'year', 'initialMileage', 'currentMileage', 'createdAt']) &&
             data.make is string && data.make.size() > 0 && data.make.size() < 100 &&
             data.model is string && data.model.size() > 0 && data.model.size() < 100 &&
             data.year is int && data.year > 1900 && data.year < 2100 &&
             data.initialMileage is int && data.initialMileage >= 0 &&
             data.currentMileage is int && data.currentMileage >= data.initialMileage;
    }

    // Service Entry Rules
    match /serviceEntries/{entryId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if incomingDocOwner() && isValidServiceEntry(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && incomingDocOwner() && isValidServiceEntry(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    function isValidServiceEntry(data) {
      return data.keys().hasAll(['id', 'vehicleId', 'uid', 'type', 'date', 'mileage', 'cost', 'createdAt']) &&
             data.type in ['oil_change', 'tire_rotation', 'brake_check', 'other'] &&
             data.mileage is int && data.mileage >= 0 &&
             data.cost is number && data.cost >= 0;
    }
  }
}
