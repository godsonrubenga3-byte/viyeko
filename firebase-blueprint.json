{
  "entities": {
    "Vehicle": {
      "title": "Vehicle",
      "description": "A vehicle in the user's digital garage.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "integer" },
        "initialMileage": { "type": "integer" },
        "currentMileage": { "type": "integer" },
        "createdAt": { "type": "integer" }
      },
      "required": ["id", "uid", "make", "model", "year", "initialMileage", "currentMileage", "createdAt"]
    },
    "ServiceEntry": {
      "title": "Service Entry",
      "description": "A maintenance or repair record for a vehicle.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["oil_change", "tire_rotation", "brake_check", "other"] },
        "date": { "type": "string", "format": "date" },
        "mileage": { "type": "integer" },
        "cost": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["id", "vehicleId", "uid", "type", "date", "mileage", "cost", "createdAt"]
    },
    "Request": {
      "title": "Service Request",
      "description": "A roadside assistance or maintenance request.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "serviceId": { "type": "string" },
        "addOnIds": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["searching", "assigned", "on-the-way", "arrived", "in-progress", "completed"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          },
          "required": ["address"]
        },
        "timestamp": { "type": "integer" },
        "vehicleInfo": { "type": "string" },
        "notes": { "type": "string" },
        "estimatedArrival": { "type": "integer" },
        "totalCost": { "type": "number" }
      },
      "required": ["id", "uid", "serviceId", "status", "location", "timestamp", "vehicleInfo", "totalCost"]
    },
    "Lead": {
      "title": "Waitlist Lead",
      "description": "Information collected from interested users prior to launch.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "vehicleType": { "type": "string" },
        "region": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["id", "name", "email", "phone", "vehicleType", "region", "createdAt"]
    }
  },
  "firestore": {
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "User vehicles."
    },
    "/serviceEntries/{entryId}": {
      "schema": "ServiceEntry",
      "description": "Maintenance records."
    },
    "/requests/{requestId}": {
      "schema": "Request",
      "description": "Roadside assistance and service requests."
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Waitlist details for early access users."
    }
  }
}
